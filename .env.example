# Rota 013 — variáveis de ambiente
# Copie para .env.local para rodar localmente. NÃO versione valores reais.
# Em produção, tudo isto é configurado nas Environment Variables da Vercel.

# --- Público (exposto no bundle do navegador, prefixo VITE_) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PROJECT_ID=seu-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY=AIza...
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID=

# --- Servidor (segredos — nunca com prefixo VITE_) ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_secreta
GOOGLE_MAPS_SERVER_KEY=AIza...
RESEND_API_KEY=re_xxx
RESEND_FROM=Rota 013 <no-reply@rota013.com.br>
